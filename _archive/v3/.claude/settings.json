{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "BASH_MAX_TIMEOUT_MS": "40000",
    "BASH_MAX_OUTPUT_LENGTH": "150000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "ENABLE_BACKGROUND_TASKS": "1",
    "MAX_THINKING_TOKENS": "31999",
    "MCP_TIMEOUT": "30000",
    "MCP_TOOL_TIMEOUT": "60000",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_ENABLE_UNIFIED_READ_TOOL": "true",
    "USE_BUILTIN_RIPGREP": "0",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "100000"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Edit:*",
      "Write:*",
      "MultiEdit:*",
      "NotebookEdit:*",
      "Bash:*",
      "WebSearch:*",
      "WebFetch:*",
      "Bash(grep:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(tree:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(psql:*)",
      "Bash(createdb:*)",
      "Bash(curl:*)",
      "Bash(wrangler:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(find:*)",
      "Bash(wait)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(openssl:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(cat:*)",
      "Bash(tail:*)"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "enabledMcpjsonServers": ["sequential-thinking"],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/skill-activation-prompt.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/install_pkgs.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/validate-skill-rules.sh"
          },
          {
            "type": "command",
            "command": "echo \"Current date: $(date '+%Y-%m-%d') | Year: $(date +%Y)\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "q=$(cat | jq -r '.tool_input.query'); y=$(date +%Y); echo $q | grep -qE '20[0-9]{2}|latest|recent|current|new|now|today' && nq=\"$q\" || nq=\"$q $y\"; echo \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PreToolUse\\\",\\\"permissionDecision\\\":\\\"allow\\\",\\\"updatedInput\\\":{\\\"query\\\":\\\"$nq\\\"}}}\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {}
}
