#!/bin/sh

echo "🔍 Validating Etus Plugins..."

# === Plugin validation ===
for plugin_dir in plugins/*/; do
  plugin_name=$(basename "$plugin_dir")
  manifest="$plugin_dir.claude-plugin/plugin.json"

  if [ ! -f "$manifest" ]; then
    echo "❌ Missing plugin.json: $manifest"
    exit 1
  fi

  if ! ruby -rjson -e "JSON.parse(File.read('$manifest'))" 2>/dev/null; then
    echo "❌ Invalid JSON: $manifest"
    exit 1
  fi

  name=$(ruby -rjson -e "puts JSON.parse(File.read('$manifest'))['name']")
  version=$(ruby -rjson -e "puts JSON.parse(File.read('$manifest'))['version']")

  if [ -d "$plugin_dir/skills" ]; then
    for skill_dir in "$plugin_dir/skills"/*/; do
      if [ ! -f "$skill_dir/SKILL.md" ]; then
        echo "❌ Missing SKILL.md: $skill_dir"
        exit 1
      fi
    done
  fi

  # Check no long model names in plugin skills
  if grep -rq "model: claude-" "$plugin_dir/skills/" 2>/dev/null; then
    echo "❌ Found long model names in $plugin_dir/skills/ — use 'opus' or 'sonnet'"
    exit 1
  fi

  skill_count=$(ls -d "$plugin_dir/skills"/*/ 2>/dev/null | wc -l | tr -d ' ')
  echo "  ✓ $plugin_name v$version ($skill_count skills)"
done

# === Marketplace validation ===
marketplace=".claude-plugin/marketplace.json"
if [ -f "$marketplace" ]; then
  if ! ruby -rjson -e "JSON.parse(File.read('$marketplace'))" 2>/dev/null; then
    echo "❌ Invalid marketplace.json"
    exit 1
  fi
  echo "  ✓ marketplace.json valid"
fi

# === Source validation (if .claude/ exists) ===
if [ -d ".claude/skills" ]; then
  for f in .claude/skills/discovery/ideate/knowledge/coverage-matrix.yaml .claude/skills/discovery/ideate/knowledge/elicitation-state.yaml; do
    if [ -f "$f" ]; then
      if ! ruby -ryaml -e "YAML.safe_load(File.read('$f'))" 2>/dev/null; then
        echo "❌ Invalid YAML: $f"
        exit 1
      fi
    fi
  done
  echo "  ✓ Source YAML files valid"
fi

# === Drift detection: plugins/pm/skills/ vs .claude/skills/ ===
if [ -f "scripts/check-drift.sh" ]; then
  sh scripts/check-drift.sh
  if [ $? -ne 0 ]; then
    echo "❌ Drift detected between .claude/ and plugins/pm/"
    exit 1
  fi
fi

# === Changeset enforcement ===
if [ -f "scripts/check-changeset.sh" ]; then
  sh scripts/check-changeset.sh
  if [ $? -ne 0 ]; then
    echo "❌ Missing changeset for release-relevant changes"
    exit 1
  fi
fi

echo "✅ All checks passed"
